Options -MultiViews
DirectoryIndex index.html

RewriteEngine On

# Maintenance mode: public visitors see maintenance, preview token can set the override cookie client-side.
RewriteCond %{QUERY_STRING} !(^|&)preview=ZAwNoPDllgzVhHBNFsVpFvJItCnYUDkxjotsyLgUgOfUBkiBnD(&|$)
RewriteCond %{HTTP_COOKIE} !(^|;\ *)maintenance_override=true(;|$)
RewriteCond %{REQUEST_URI} !^/maintenance\.html$ [NC]
RewriteCond %{REQUEST_URI} !^/assets/ [NC]
RewriteCond %{REQUEST_URI} !^/robots\.txt$ [NC]
RewriteCond %{REQUEST_URI} !^/sitemap\.xml$ [NC]
RewriteRule ^.*$ /maintenance.html [R=302,L]

# Clean old direct file URLs.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ ./ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+)/index\.html[\s?] [NC]
RewriteRule ^(.+)/index\.html$ $1/ [R=301,L]

RewriteRule ^download\.html$ download/ [R=301,L]

# Allow future simple pages: /nome instead of /nome.html.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>
